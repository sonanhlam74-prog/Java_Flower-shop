<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<VBox alignment="CENTER" prefHeight="520.0" prefWidth="580.0" spacing="0.0"
    styleClass="auth-root"
    xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.LoginController">
    <children>
        <!-- Thanh trang trí phía trên -->
        <HBox styleClass="auth-topbar" alignment="CENTER">
            <children>
                <Label text="🌸 Flower Shop" styleClass="auth-brand" />
            </children>
            <padding><Insets bottom="10.0" left="24.0" right="24.0" top="10.0" /></padding>
        </HBox>

        <!-- Thẻ -->
        <VBox alignment="TOP_LEFT" maxWidth="420.0" spacing="10.0" styleClass="auth-card">
            <children>
                <Label text="🌺" styleClass="auth-icon" />
                <Label text="Đăng nhập hệ thống" styleClass="auth-title" />
                <Label text="Vui lòng đăng nhập để truy cập quản lý" styleClass="auth-subtitle" />

                <Region prefHeight="6.0" />

                <Label text="Tài khoản" styleClass="field-label" />
                <TextField fx:id="txtUsername" promptText="Nhập tài khoản" styleClass="auth-input" />

                <Label text="Mật khẩu" styleClass="field-label" />
                <StackPane alignment="CENTER_RIGHT">
                    <PasswordField fx:id="txtPassword" onAction="#handleLogin" promptText="Nhập mật khẩu" styleClass="auth-input" />
                    <TextField fx:id="txtPasswordVisible" onAction="#handleLogin" promptText="Nhập mật khẩu" styleClass="auth-input" />
                    <Button fx:id="btnTogglePassword" onAction="#handleTogglePassword" text="👁" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 16px;">
                        <StackPane.margin>
                            <Insets right="8.0" />
                        </StackPane.margin>
                    </Button>
                </StackPane>

                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Button onAction="#handleForgotPassword" styleClass="auth-link-btn" text="Quên mật khẩu?" />
                    </children>
                </HBox>

                <Button defaultButton="true" maxWidth="999999" onAction="#handleLogin" styleClass="auth-primary-btn" text="🔓 Đăng nhập" />
                <Button maxWidth="999999" onAction="#handleBackToShop" styleClass="auth-secondary-btn" text="← Về cửa hàng" />

                <HBox alignment="CENTER" spacing="6.0">
                    <children>
                        <Label text="Chưa có tài khoản?" styleClass="auth-hint" />
                        <Button onAction="#handleGoToRegister" styleClass="auth-link-btn" text="Đăng ký ngay" />
                    </children>
                </HBox>

                <Label text="Demo: admin / 123456" styleClass="auth-hint" />
            </children>
            <padding><Insets bottom="28.0" left="32.0" right="32.0" top="24.0" /></padding>
        </VBox>
    </children>
</VBox>
