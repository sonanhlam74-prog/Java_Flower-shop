<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="560.0" prefWidth="580.0" spacing="0.0"
    styleClass="auth-root"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.RegisterController">
    <children>
        <!-- Thanh trang trí phía trên -->
        <HBox styleClass="auth-topbar" alignment="CENTER">
            <children>
                <Label text="🌸 Flower Shop" styleClass="auth-brand" />
            </children>
            <padding><Insets bottom="10.0" left="24.0" right="24.0" top="10.0" /></padding>
        </HBox>

        <!-- Thẻ -->
        <VBox alignment="TOP_LEFT" maxWidth="420.0" spacing="10.0" styleClass="auth-card">
            <children>
                <Label text="🌿" styleClass="auth-icon" />
                <Label text="Tạo tài khoản mới" styleClass="auth-title" />
                <Label text="Đăng ký để quản lý cửa hàng hoa" styleClass="auth-subtitle" />

                <Region prefHeight="6.0" />

                <Label text="Họ và tên" styleClass="field-label" />
                <TextField fx:id="txtFullName" promptText="Nhập họ và tên" styleClass="auth-input" />

                <Label text="Email" styleClass="field-label" />
                <TextField fx:id="txtEmail" promptText="example@email.com" styleClass="auth-input" />

                <Label text="Tài khoản" styleClass="field-label" />
                <TextField fx:id="txtUsername" promptText="Nhập tài khoản" styleClass="auth-input" />

                <Label text="Mật khẩu" styleClass="field-label" />
                <PasswordField fx:id="txtPassword" promptText="Ít nhất 6 ký tự" styleClass="auth-input" />

                <Label text="Xác nhận mật khẩu" styleClass="field-label" />
                <PasswordField fx:id="txtConfirmPassword" onAction="#handleRegister" promptText="Nhập lại mật khẩu" styleClass="auth-input" />

                <Region prefHeight="4.0" />

                <Button defaultButton="true" maxWidth="999999" onAction="#handleRegister" styleClass="auth-primary-btn" text="🚀 Đăng ký" />

                <HBox alignment="CENTER" spacing="6.0">
                    <children>
                        <Label text="Đã có tài khoản?" styleClass="auth-hint" />
                        <Button onAction="#handleGoToLogin" styleClass="auth-link-btn" text="Đăng nhập" />
                    </children>
                </HBox>
            </children>
            <padding><Insets bottom="28.0" left="32.0" right="32.0" top="24.0" /></padding>
        </VBox>
    </children>
</VBox>
